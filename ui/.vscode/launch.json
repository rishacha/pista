{
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "SvelteKit Debug",
            "program": "${workspaceFolder}/node_modules/vite/bin/vite.js",
            "args": ["--port", "3000"],
            "autoAttachChildProcesses": true,
            "sourceMaps": true,
            "skipFiles": ["<node_internals>/**"],
            "outFiles": ["${workspaceFolder}/**/*.js"]
          }
    ]
}